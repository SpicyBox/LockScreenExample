<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="50dp"
        android:text="문제"
        android:textSize="35dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center">

        <TextView
            android:id="@+id/textView2"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:gravity="center"
            android:text="생활영어" />

        <TextView
            android:id="@+id/textView3"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="15dp"
            android:layout_weight="1"
            android:text="\n실생활에서 자주 쓰이는 간단한 영어 단어들이 나옵니다. 회화실력을 늘리고 싶다면 추천!"
            android:textAlignment="textStart" />

        <Button
            android:id="@+id/englishWordBtn"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:text="시작하기!" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/lifeTypeMaxScoreTxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="최고점수" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center">

        <TextView
            android:id="@+id/textView4"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:gravity="center"
            android:text="토익단어" />

        <TextView
            android:id="@+id/textView5"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="15dp"
            android:layout_weight="1"
            android:text="\n토익 문제에서 자주 나오는 단어들이 나옵니다. 토익을 준비하는 시험생들에게 추천!"
            android:textAlignment="textStart" />

        <Button
            android:id="@+id/englishMeanBtn"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:text="시작하기" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/toeicTypeMaxScoreTxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="최고점수" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center">

        <TextView
            android:id="@+id/textView6"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:gravity="center"
            android:text="논술영어" />

        <TextView
            android:id="@+id/textView7"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_margin="15dp"
            android:layout_weight="1"
            android:text="\n학술지에 자주 쓰이는 단어들이 나옵니다. 해외 저널을 읽어야 하는 전문가들에게 추천!"
            android:textAlignment="textStart" />

        <Button
            android:id="@+id/englishAlpabetBtn"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:text="시작하기" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/journalTypeMaxScoreTxt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="최고점수" />

    </LinearLayout>

</LinearLayout>